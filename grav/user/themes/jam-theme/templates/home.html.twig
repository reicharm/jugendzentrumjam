{% include 'partials/header.html.twig' %}

<section class="intro">
    <h1>{{ page.title }}</h1>
    <div class="page-content">{{ page.content }}</div>
</section>

{% set news_page = page.find('/neuigkeiten') %}
{% set event_page = page.find('/termine') %}

<section class="home-section">
    <h2>Aktuelle Neuigkeiten</h2>
    {% if news_page %}
        {% set news_items = news_page.collection.order('date', 'desc')|slice(0, config.theme.home_news_count) %}
        {% if news_items|length %}
            <div class="news-grid">
                {% for item in news_items %}
                    <article class="news-card">
                        <a href="{{ item.url }}">
                            {% if item.media.images|length %}
                                <img class="news-card-image" src="{{ (item.media.images|first).value.cropZoom(600, 450).url }}" alt="{{ item.title }}" loading="lazy">
                            {% else %}
                                <div class="news-card-image"></div>
                            {% endif %}
                            <div class="news-card-body">
                                <span class="news-card-date">{{ item.date|date('d.m.Y') }}</span>
                                <h3 class="news-card-title">{{ item.title }}</h3>
                                {% if item.summary %}<p class="news-card-excerpt">{{ item.summary|striptags }}</p>{% endif %}
                            </div>
                        </a>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <p>Aktuell keine Neuigkeiten.</p>
        {% endif %}
    {% endif %}
    <a class="more-link" href="{{ base_url }}/neuigkeiten">Alle Neuigkeiten &rarr;</a>
</section>

<section class="home-section">
    <h2>Nächste Termine</h2>
    {% if event_page %}
        {% set event_items = event_page.collection.order('header.event_date', 'asc') %}
        {% set upcoming = [] %}
        {% for item in event_items %}
            {% if item.header.event_date and item.header.event_date|date('U') >= "now"|date('U') %}
                {% set upcoming = upcoming|merge([item]) %}
            {% endif %}
        {% endfor %}
        {% set upcoming = upcoming|slice(0, config.theme.home_events_count) %}
        {% if upcoming|length %}
            <ul class="event-list">
                {% for item in upcoming %}
                    <li class="event-row">
                        <a href="{{ item.url }}" style="display:flex; align-items:center; gap:1rem; flex:1;">
                            <span class="event-date-badge">
                                <span class="day">{{ item.header.event_date|date('d') }}</span>
                                <span class="month">{{ item.header.event_date|date('M') }}</span>
                            </span>
                            <span>
                                <span class="event-title">{{ item.title }}</span>
                                <p class="event-meta">
                                    {% if item.header.event_time %}{{ item.header.event_time }} Uhr{% endif %}
                                    {% if item.header.event_location %} &middot; {{ item.header.event_location }}{% endif %}
                                </p>
                            </span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>Aktuell keine anstehenden Termine.</p>
        {% endif %}
    {% endif %}
    <a class="more-link" href="{{ base_url }}/termine">Alle Termine &rarr;</a>
</section>

{% include 'partials/instagram.html.twig' %}

{% include 'partials/footer.html.twig' %}
