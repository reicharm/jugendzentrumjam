{% include 'partials/header.html.twig' %}

<h1>{{ page.title }}</h1>

{% set all_items = page.collection.order('header.event_date', 'asc') %}
{% set upcoming = [] %}
{% set past = [] %}
{% for item in all_items %}
    {% if item.header.event_date and item.header.event_date|date('U') >= "today"|date('U') %}
        {% set upcoming = upcoming|merge([item]) %}
    {% else %}
        {% set past = past|merge([item]) %}
    {% endif %}
{% endfor %}

<h2>Anstehende Termine</h2>
{% if upcoming|length %}
    <ul class="event-list">
        {% for item in upcoming %}
            <li class="event-row">
                <a href="{{ item.url }}" style="display:flex; align-items:center; gap:1rem; flex:1;">
                    <span class="event-date-badge">
                        <span class="day">{{ item.header.event_date|date('d') }}</span>
                        <span class="month">{{ item.header.event_date|date('M') }}</span>
                    </span>
                    <span>
                        <span class="event-title">{{ item.title }}</span>
                        <p class="event-meta">
                            {% if item.header.event_time %}{{ item.header.event_time }} Uhr{% endif %}
                            {% if item.header.event_location %} &middot; {{ item.header.event_location }}{% endif %}
                        </p>
                    </span>
                </a>
            </li>
        {% endfor %}
    </ul>
{% else %}
    <p>Aktuell keine anstehenden Termine.</p>
{% endif %}

{% if past|length %}
    <details class="past-events">
        <summary>Vergangene Termine</summary>
        <ul class="event-list">
            {% for item in past|reverse %}
                <li class="event-row">
                    <a href="{{ item.url }}" style="display:flex; align-items:center; gap:1rem; flex:1;">
                        <span class="event-date-badge">
                            <span class="day">{{ item.header.event_date|date('d') }}</span>
                            <span class="month">{{ item.header.event_date|date('M') }}</span>
                        </span>
                        <span class="event-title">{{ item.title }}</span>
                    </a>
                </li>
            {% endfor %}
        </ul>
    </details>
{% endif %}

{% include 'partials/footer.html.twig' %}
